{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issues-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "status", "plan_ref", "contract_ref", "issues"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"const": "1"},
    "status": {"enum": ["draft", "approved"]},
    "plan_ref": {"type": "string", "minLength": 1},
    "contract_ref": {"type": "string", "minLength": 1},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "type", "pbs_leaf", "blocked_by", "story_refs", "technical_enabler_for", "criterion_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "type": {"enum": ["HITL", "AFK"]},
          "pbs_leaf": {"type": "string", "minLength": 1},
          "blocked_by": {"type": "array", "items": {"type": "string"}},
          "story_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^US-[A-Z0-9-]+$"}},
          "technical_enabler_for": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^US-[A-Z0-9-]+$"}},
          "criterion_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        },
        "anyOf": [
          {"properties": {"story_refs": {"minItems": 1}}, "required": ["story_refs"]},
          {"properties": {"technical_enabler_for": {"minItems": 1}}, "required": ["technical_enabler_for"]}
        ]
      }
    }
  },
  "allOf": [{
    "if": {"properties": {"status": {"const": "approved"}}, "required": ["status"]},
    "then": {"properties": {"issues": {"minItems": 1}}}
  }]
}
