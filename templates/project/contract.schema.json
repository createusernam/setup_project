{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract.schema.json",
  "title": "Setup delivery contract",
  "type": "object",
  "required": ["version", "scope", "created", "is_frontend", "is_backend", "is_architecturally_complex", "linked_plan", "linked_product_brief", "user_flow", "integrations", "criteria", "out_of_scope", "judge_required", "grace_mode"],
  "properties": {
    "$schema": {"type": "string"},
    "_comment": {"type": "string"},
    "version": {"const": "2"},
    "scope": {"type": "string"},
    "created": {"type": "string"},
    "is_frontend": {"type": ["boolean", "null"]},
    "is_backend": {"type": ["boolean", "null"]},
    "is_architecturally_complex": {"type": ["boolean", "null"]},
    "linked_issue": {"type": ["string", "null"]},
    "linked_plan": {"type": "string", "minLength": 1},
    "linked_cjm": {"type": ["string", "null"]},
    "linked_product_brief": {"type": "string", "minLength": 1},
    "inherits": {"type": "array", "items": {"type": "string"}},
    "user_flow": {
      "type": "object",
      "required": ["jtbd", "primary_path", "error_paths"],
      "properties": {
        "linked_cjm": {"type": ["string", "null"]},
        "jtbd": {"type": "string"},
        "primary_path": {"type": "array"},
        "error_paths": {"type": "array"}
      }
    },
    "integrations": {
      "type": "object",
      "required": ["data_flow", "frontend_calls", "backend_endpoints", "schema_changes", "external_services"],
      "properties": {
        "data_flow": {"type": "string"},
        "frontend_calls": {"type": "array"},
        "backend_endpoints": {"type": "array"},
        "schema_changes": {"type": "array"},
        "external_services": {"type": "array"}
      }
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "weight", "must_pass", "check", "verify"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "minimum": 0},
          "must_pass": {"type": "boolean"},
          "check": {"type": "string", "minLength": 1},
          "verify": {"type": "object"}
        }
      }
    },
    "out_of_scope": {"type": "array"},
    "judge_required": {"type": "boolean"},
    "grace_mode": {"type": "string", "minLength": 1}
  }
}
