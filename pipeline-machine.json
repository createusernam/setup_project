{
  "version": "1.1",
  "description": "Executable transition contract for the setup pipeline. Prose explains transitions; this file authorizes them.",
  "risk_policy": {
    "default": "T3",
    "tiers": {
      "T0": {"label": "mechanical", "criteria": "typo, config, or deterministic edit; reversible; one boundary", "required_phases": ["7"]},
      "T1": {"label": "bounded_bugfix", "criteria": "reproduced defect with bounded blast radius", "required_phases": ["7"]},
      "T2": {"label": "small_reversible_feature", "criteria": "small reversible feature across at most two boundaries", "required_phases": ["1", "2", "4", "4b", "4c", "5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}},
      "T3": {"label": "cross_module_or_high_risk", "criteria": "cross-module change, high uncertainty, or costly rework", "required_phases": ["-1", "1", "2", "2-PM", "2b", "4", "4b", "4c", "5", "5.5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}},
      "T4": {"label": "safety_regulatory_irreversible", "criteria": "safety, regulatory, security, privacy, or irreversible impact", "required_phases": ["-1", "1", "2", "2-PM", "2b", "3r", "4", "4b", "4c", "5", "5.5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}}
    },
    "selection_factors": ["reversibility", "blast_radius", "uncertainty", "boundary_count", "cost_of_error"]
  },
  "transitions": {
    "-1": {"skill": "discovery process", "tiers": ["T3", "T4"], "requires": []},
    "0": {
      "skill": "researcher", "tiers": ["T2", "T3", "T4"],
      "when": {"condition": "research_required", "equals": true},
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "in": ["alpha", "delivery"]}
      ]
    },
    "1": {
      "skill": "grill-with-docs", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "equals": "delivery"},
        {"artifact": "business_model.md", "attested": true},
        {"artifact": "docs/research-state.json", "attested": true, "when": {"condition": "research_required", "equals": true}}
      ]
    },
    "2": {
      "skill": "planning-with-files", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/validation_stage", "in": ["alpha", "live"]},
        {"artifact": "CONTEXT.md", "attested": true}
      ]
    },
    "2-PM": {
      "skill": "pm-review", "tiers": ["T3", "T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "product_brief.md", "attested": true}
      ]
    },
    "2b": {
      "skill": "grace-init, grace-plan", "tiers": ["T3", "T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE"}
      ]
    },
    "3": {
      "skill": "design-rubric, design-first", "tiers": ["T2", "T3", "T4"],
      "when": {"condition": "frontend", "equals": true},
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE", "tiers": ["T3", "T4"]}
      ]
    },
    "3r": {
      "skill": "risk-review", "tiers": ["T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE"},
        {"artifact": "docs/knowledge-graph.xml", "attested": true}
      ]
    },
    "4": {
      "skill": "contract", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "equals": "delivery"},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE", "tiers": ["T3", "T4"]},
        {"artifact": "docs/requirements.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/technology.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/development-plan.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/verification-plan.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/knowledge-graph.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/operational-packets.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "design-contract.json", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": ".design-contract-attestation", "sha256_of": "design-contract.json", "when": {"condition": "frontend", "equals": true}},
        {"artifact": "api-contract.json", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": "docs/wireframe-*.md", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": "risk-review.json", "attested": true, "json_pointer": "/verdict", "equals": "PASS", "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/status", "in": ["ready", "complete"], "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/rollback/defined", "equals": true, "tiers": ["T4"]}
      ]
    },
    "4b": {
      "skill": "judge contract", "tiers": ["T2", "T3", "T4"],
      "requires": [{"artifact": "contract.json", "attested": true}]
    },
    "4c": {
      "skill": "visualization", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS"}
      ]
    },
    "5": {
      "skill": "to-issues", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS"},
        {"artifact": "SUPERVISION.md", "attested": true}
      ],
      "human_gate": "viz_before_tickets"
    },
    "5.5": {
      "skill": "scaffold", "tiers": ["T3", "T4"],
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "issues-manifest.json", "attested": true, "json_pointer": "/status", "equals": "approved"},
        {"artifact": "docs/knowledge-graph.xml", "attested": true}
      ]
    },
    "6": {
      "skill": "build-loop, tdd", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "issues-manifest.json", "attested": true, "json_pointer": "/status", "equals": "approved"},
        {"artifact": "scaffold-manifest.json", "attested": true, "json_pointer": "/status", "equals": "ready", "tiers": ["T3", "T4"]}
      ],
      "human_gate": "contract_locked"
    },
    "7": {
      "skill": "judge feature, code-review-expert", "tiers": ["T0", "T1", "T2", "T3", "T4"],
      "requires": [
        {"artifact": "build-evidence.json", "attested": true, "json_pointer": "/status", "equals": "complete"},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/status", "in": ["ready", "complete"], "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/rollback/defined", "equals": true, "tiers": ["T4"]}
      ],
      "completion": {
        "requires": [
          {"artifact": "code-review.md", "attested": true},
          {"artifact": "feature-judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS", "tiers": ["T2", "T3", "T4"]}
        ],
        "human_gate": "human_acceptance"
      }
    }
  },
  "artifact_owners": {
    "product_brief.md": {"producer_phase": "-1", "template": "templates/project/product_brief.md"},
    "evidence-handoff.json": {"producer_phase": "-1", "template": "templates/project/evidence-handoff.json"},
    "business_model.md": {"producer_phase": "-1"},
    "docs/research-state.json": {"producer_phase": "0"},
    "CONTEXT.md": {"producer_phase": "1"},
    "task_plan.md": {"producer_phase": "2"},
    "pm-review.json": {"producer_phase": "2-PM"},
    "docs/requirements.xml": {"producer_phase": "2b"},
    "docs/technology.xml": {"producer_phase": "2b"},
    "docs/development-plan.xml": {"producer_phase": "2b", "template": "templates/project/docs/development-plan.xml"},
    "docs/verification-plan.xml": {"producer_phase": "2b", "template": "templates/project/docs/verification-plan.xml"},
    "docs/knowledge-graph.xml": {"producer_phase": "2b", "template": "templates/project/docs/knowledge-graph.xml"},
    "docs/operational-packets.xml": {"producer_phase": "2b"},
    "design-contract.json": {"producer_phase": "3"},
    ".design-contract-attestation": {"producer_phase": "3"},
    "api-contract.json": {"producer_phase": "3"},
    "docs/wireframe-*.md": {"producer_phase": "3"},
    "risk-review.json": {"producer_phase": "3r", "template": "templates/project/risk-review.json"},
    "rollout-plan.json": {"producer_phase": "3r", "template": "templates/project/rollout-plan.json"},
    "contract.json": {"producer_phase": "4", "template": "templates/project/contract.json"},
    "judge-report.json": {"producer_phase": "4b"},
    "SUPERVISION.md": {"producer_phase": "4c"},
    "issues-manifest.json": {"producer_phase": "5", "template": "templates/project/issues-manifest.json"},
    "scaffold-manifest.json": {"producer_phase": "5.5", "template": "templates/project/scaffold-manifest.json"},
    "build-evidence.json": {"producer_phase": "6", "template": "templates/project/build-evidence.json"},
    "feature-judge-report.json": {"producer_phase": "7"},
    "code-review.md": {"producer_phase": "7"}
  },
  "gate_owners": {
    "contract_locked": "4b",
    "viz_before_tickets": "4c",
    "human_acceptance": "7"
  },
  "invalidations": {
