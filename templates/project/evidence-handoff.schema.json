{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-handoff.schema.json",
  "title": "Evidence handoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "validation_stage", "decision", "claims", "open_questions", "assumptions", "cheapest_next_experiment"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"const": "1"},
    "validation_stage": {"enum": ["discovery", "alpha", "live"]},
    "decision": {"enum": ["stop", "alpha", "delivery"]},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_refs", "falsifier"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["hypothesis", "case_supported", "segment_supported", "behavior_supported", "commercially_supported"]},
          "evidence_refs": {"type": "array"},
          "falsifier": {"type": "string", "minLength": 1}
        }
      }
    },
    "open_questions": {"type": "array"},
    "assumptions": {"type": "array"},
    "spec_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "statement", "impact", "materiality", "owner", "disposition", "status", "evidence_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["missing_behavior", "ambiguity", "conflict", "technical_unknown"]},
          "statement": {"type": "string", "minLength": 1},
          "impact": {"enum": ["scope", "user_flow", "architecture", "acceptance"]},
          "materiality": {"enum": ["blocking", "bounded", "cosmetic"]},
          "owner": {"type": "string", "minLength": 1},
          "disposition": {"enum": ["answer", "prototype", "accept_risk", "out_of_scope"]},
          "status": {"enum": ["open", "resolved", "accepted", "out_of_scope"]},
          "resolution_ref": {"type": ["string", "null"]},
          "accepted_by": {"type": ["string", "null"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      },
      "default": []
    },
    "cheapest_next_experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis", "prototype", "observable_result", "promotion_rule", "kill_rule"],
      "properties": {
        "type": {"enum": ["problem", "semantic", "technical"]},
        "hypothesis": {"type": "string"},
        "prototype": {"type": "string"},
        "observable_result": {"type": "string"},
        "comparison_questions": {"type": "array", "items": {"type": "string"}},
        "promotion_rule": {"type": "string"},
        "kill_rule": {"type": "string"}
      }
    }
  }
}
