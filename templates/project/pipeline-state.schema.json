{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline-state.schema.json",
  "title": "Setup project pipeline ledger",
  "type": "object",
  "required": ["version", "phase", "policy", "artifacts", "human_gates", "phase_processes", "model_bindings_file"],
  "properties": {
    "version": {"const": "2"},
    "phase": {"enum": ["-1", "0", "1", "2", "2-PM", "2b", "3", "3r", "4", "4b", "4c", "5", "5.5", "6", "7"]},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_tier", "conditions"],
      "properties": {
        "risk_tier": {"enum": [null, "T0", "T1", "T2", "T3", "T4"]},
        "tier_reason": {"type": "string", "minLength": 1},
        "conditions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["research_required", "frontend"],
          "properties": {
            "research_required": {"type": ["boolean", "null"]},
            "frontend": {"type": ["boolean", "null"]}
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha256", "status", "invalidated_by"],
        "properties": {
          "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
          "status": {"enum": ["draft", "ready", "approved", "complete", "invalidated"]},
          "invalidated_by": {"type": ["string", "null"]}
        }
      }
    },
    "human_gates": {
      "type": "object",
      "required": ["viz_before_tickets", "contract_locked", "human_acceptance"],
      "additionalProperties": false,
      "properties": {
        "viz_before_tickets": {"$ref": "#/$defs/signature"},
        "contract_locked": {"$ref": "#/$defs/signature"},
        "human_acceptance": {"$ref": "#/$defs/signature"}
      }
    },
    "phase_processes": {
      "type": "object",
      "propertyNames": {"enum": ["-1", "0", "1", "2", "2-PM", "2b", "3", "3r", "4", "4b", "4c", "5", "5.5", "6", "7"]},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill"],
        "properties": {"skill": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"}}
      }
    },
    "model_bindings_file": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.json$"}
  },
  "$defs": {
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by", "at"],
      "properties": {
        "by": {"type": ["string", "null"]},
        "at": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
