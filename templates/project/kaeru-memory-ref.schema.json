{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kaeru-memory-ref.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "memory_ref", "project_id", "task_id", "kind", "status", "source_refs", "authority", "visibility", "valid_at", "recorded_at"],
  "properties": {
    "$schema": {"type": "string"},
    "memory_ref": {"type": "string", "pattern": "^kaeru://"},
    "project_id": {"type": "string", "minLength": 1},
    "task_id": {"type": ["string", "null"]},
    "kind": {"enum": ["episode", "claim", "experiment", "lesson", "reference"]},
    "status": {"enum": ["candidate", "supported", "refuted", "settled"]},
    "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "authority": {"enum": ["agent", "human", "machine"]},
    "visibility": {"enum": ["private", "shared"]},
    "valid_at": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"}
  }
}
