{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "behavior-index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "flows", "use_cases", "interactions", "risk_probes", "coverage"],
  "properties": {
    "version": {"const": "1"},
    "flows": {"type": "array", "items": {"$ref": "#/$defs/flow"}},
    "use_cases": {"type": "array", "items": {"$ref": "#/$defs/use_case"}},
    "interactions": {"type": "array", "items": {"$ref": "#/$defs/interaction"}},
    "risk_probes": {"type": "array", "items": {"$ref": "#/$defs/risk_probe"}},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["uncovered_criteria", "uncovered_critical_error_paths"], "properties": {"uncovered_criteria": {"type": "array", "items": {"type": "string"}}, "uncovered_critical_error_paths": {"type": "array", "items": {"type": "string"}}}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9-]*$"},
    "relative_path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.(?:md|json)$"},
    "flow": {"type": "object", "additionalProperties": false, "required": ["id", "path", "use_case_ids", "criterion_refs"], "properties": {"id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/relative_path"}, "use_case_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}}, "criterion_refs": {"type": "array", "items": {"type": "string"}}}},
    "step": {"type": "object", "additionalProperties": false, "required": ["number", "text"], "properties": {"number": {"type": "integer", "minimum": 1}, "text": {"type": "string", "minLength": 1}}},
    "use_case": {"type": "object", "additionalProperties": false, "required": ["id", "path", "flow_id", "steps", "contract_paths", "critical"], "properties": {"id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/relative_path"}, "flow_id": {"$ref": "#/$defs/id"}, "steps": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/step"}}, "contract_paths": {"type": "array", "items": {"type": "string"}}, "critical": {"type": "boolean"}}},
    "interaction": {"type": "object", "additionalProperties": false, "required": ["id", "path", "use_case_id", "step", "question", "lifeline_count", "node_count", "max_nesting", "split_justification"], "properties": {"id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/relative_path"}, "use_case_id": {"$ref": "#/$defs/id"}, "step": {"type": "integer", "minimum": 1}, "question": {"type": "string", "minLength": 1}, "lifeline_count": {"type": "integer", "minimum": 1}, "node_count": {"type": "integer", "minimum": 1}, "max_nesting": {"type": "integer", "minimum": 0}, "split_justification": {"type": ["string", "null"]}}},
    "risk_probe": {"type": "object", "additionalProperties": false, "required": ["spec_gap_id", "hypothesis", "evidence_ref", "verdict", "delegation_boundary"], "properties": {"spec_gap_id": {"type": "string", "minLength": 1}, "hypothesis": {"type": "string", "minLength": 1}, "evidence_ref": {"type": "string", "minLength": 1}, "verdict": {"enum": ["resolved", "unresolved", "accepted_risk"]}, "delegation_boundary": {"type": "string", "minLength": 1}}}
  }
}
