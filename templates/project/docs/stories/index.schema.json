{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "story-index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "stories"],
  "properties": {
    "version": {"const": "1"},
    "stories": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "actor", "goal", "trigger", "outcome", "boundaries", "use_cases", "assumptions", "open_questions"],
        "properties": {
          "id": {"type": "string", "pattern": "^US-[A-Z0-9-]+$"},
          "path": {"type": "string", "pattern": "^docs/stories/US-[A-Z0-9-]+\\.md$"},
          "actor": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "trigger": {"type": "string", "minLength": 1},
          "outcome": {"type": "string", "minLength": 1},
          "boundaries": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "use_cases": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["id", "criterion_refs"],
              "properties": {
                "id": {"type": "string", "pattern": "^UC-[A-Z0-9-]+$"},
                "criterion_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
              }
            }
          },
          "assumptions": {"type": "array", "items": {"type": "string"}},
          "open_questions": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
