{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline-machine.schema.json",
  "title": "Setup pipeline machine contract",
  "type": "object",
  "required": ["version", "risk_policy", "transitions", "artifact_owners", "artifact_contracts", "invalidations", "gate_invalidations", "verification_layers"],
  "properties": {
    "version": {"type": "string"},
    "risk_policy": {
      "type": "object",
      "required": ["default", "tiers", "selection_factors"],
      "properties": {
        "default": {"enum": ["T0", "T1", "T2", "T3", "T4"]},
        "tiers": {
          "type": "object",
          "minProperties": 5,
          "additionalProperties": {
            "type": "object",
            "required": ["label", "criteria", "required_phases"],
            "properties": {
              "label": {"type": "string", "minLength": 1},
              "criteria": {"type": "string", "minLength": 1},
              "required_phases": {"type": "array", "items": {"type": "string"}},
              "conditional_phases": {
                "type": "object",
                "additionalProperties": {"$ref": "#/$defs/conditionWithDescription"}
              }
            }
          }
        }
      }
    },
    "transitions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["skill", "tiers", "requires"],
        "properties": {
          "skill": {"type": "string", "minLength": 1},
          "tiers": {"type": "array", "minItems": 1, "items": {"enum": ["T0", "T1", "T2", "T3", "T4"]}},
          "when": {"$ref": "#/$defs/condition"},
          "requires": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["artifact"],
              "properties": {
                "artifact": {"type": "string", "minLength": 1},
                "attested": {"type": "boolean"},
                "when_present": {"type": "boolean"},
                "json_pointer": {"type": "string"},
                "equals": {},
                "in": {"type": "array"},
                "when": {"$ref": "#/$defs/condition"},
                "tiers": {"type": "array", "items": {"enum": ["T0", "T1", "T2", "T3", "T4"]}}
              }
            }
          },
          "human_gate": {"type": "string"},
          "completion": {
            "type": "object",
            "required": ["requires", "human_gate"],
            "properties": {
              "requires": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["artifact"],
                  "properties": {
                    "artifact": {"type": "string", "minLength": 1},
                    "attested": {"type": "boolean"},
                    "when_present": {"type": "boolean"},
                    "json_pointer": {"type": "string"},
                    "equals": {},
                    "in": {"type": "array"},
                    "when": {"$ref": "#/$defs/condition"},
                    "tiers": {"type": "array", "items": {"enum": ["T0", "T1", "T2", "T3", "T4"]}}
                  }
                }
              },
              "human_gate": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "artifact_owners": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "producer_phase": {"type": ["string", "null"]},
          "producer_phases": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "template": {"type": "string", "minLength": 1},
          "schema": {"type": "string", "minLength": 1},
          "validator": {"type": "string", "minLength": 1},
          "media_type": {"type": "string", "minLength": 1}
        },
        "anyOf": [
          {"required": ["producer_phase"]},
          {"required": ["producer_phases"]}
        ]
      }
    },
    "artifact_contracts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["producer", "media_type"],
        "properties": {
          "producer": {"type": "string", "minLength": 1},
          "schema": {"type": "string", "minLength": 1},
          "validator": {"type": "string", "minLength": 1},
          "media_type": {"type": "string", "minLength": 1}
        }
      }
    },
    "invalidations": {"type": "object"},
    "gate_invalidations": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"enum": ["contract_locked", "viz_before_tickets", "human_acceptance"]},
        "uniqueItems": true
      }
    },
    "verification_layers": {"type": "array", "minItems": 5}
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "equals"],
      "properties": {
        "condition": {"enum": ["research_required", "frontend"]},
        "equals": {"type": "boolean"}
      }
    },
    "conditionWithDescription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "equals", "description"],
      "properties": {
        "condition": {"enum": ["research_required", "frontend"]},
        "equals": {"type": "boolean"},
        "description": {"type": "string", "minLength": 1}
      }
    }
  }
}
