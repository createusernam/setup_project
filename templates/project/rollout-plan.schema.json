{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rollout-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "status", "stages", "rollback"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"const": "1"},
    "status": {"enum": ["draft", "ready", "complete"]},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "audience", "entry_condition", "success_signal", "stop_signal"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "audience": {"type": "string", "minLength": 1},
          "entry_condition": {"type": "string", "minLength": 1},
          "success_signal": {"type": "string", "minLength": 1},
          "stop_signal": {"type": "string", "minLength": 1}
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defined", "trigger", "action", "owner"],
      "properties": {
        "defined": {"type": "boolean"},
        "trigger": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1}
      }
    }
  },
  "allOf": [{
    "if": {"properties": {"status": {"enum": ["ready", "complete"]}}, "required": ["status"]},
    "then": {
      "properties": {
        "stages": {"minItems": 1},
        "rollback": {"properties": {"defined": {"const": true}}}
      }
    }
  }]
}
