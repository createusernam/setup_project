{
  "version": "1.4",
  "description": "Executable transition contract for the setup pipeline. Prose explains transitions; this file authorizes them.",
  "risk_policy": {
    "default": "T3",
    "tiers": {
      "T0": {"label": "mechanical", "criteria": "typo, config, or deterministic edit; reversible; one boundary", "required_phases": ["6f", "7"]},
      "T1": {"label": "bounded_bugfix", "criteria": "reproduced defect with bounded blast radius", "required_phases": ["6f", "7"]},
      "T2": {"label": "small_reversible_feature", "criteria": "small reversible feature across at most two boundaries", "required_phases": ["1", "2", "4", "4b", "4c", "5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}},
      "T3": {"label": "cross_module_or_high_risk", "criteria": "cross-module change, high uncertainty, or costly rework", "required_phases": ["-1", "1", "2", "2-PM", "2b", "4", "4b", "4c", "5", "5.5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}},
      "T4": {"label": "safety_regulatory_irreversible", "criteria": "safety, regulatory, security, privacy, or irreversible impact", "required_phases": ["-1", "1", "2", "2-PM", "2b", "3r", "4", "4b", "4c", "5", "5.5", "6", "7"], "conditional_phases": {"0": {"condition": "research_required", "equals": true, "description": "only when material factual gaps remain"}, "3": {"condition": "frontend", "equals": true, "description": "only when the change includes frontend behavior"}}}
    },
    "selection_factors": ["reversibility", "blast_radius", "uncertainty", "boundary_count", "cost_of_error"]
  },
  "transitions": {
    "-1": {
      "skill": "discovery process",
      "tiers": ["T3", "T4"],
      "entry_mode": "pre_route",
      "required_after_classification_for": ["T3", "T4"],
      "requires": []
    },
    "0": {
      "skill": "researcher", "tiers": ["T2", "T3", "T4"],
      "when": {"condition": "research_required", "equals": true},
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "in": ["alpha", "delivery"]}
      ]
    },
    "1": {
      "skill": "grill-with-docs", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "equals": "delivery"},
        {"artifact": "business_model.md", "attested": true, "when_present": true},
        {"artifact": "docs/research-state.json", "attested": true, "when": {"condition": "research_required", "equals": true}}
      ]
    },
    "2": {
      "skill": "planning-with-files", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "product_brief.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/validation_stage", "in": ["alpha", "live"]},
        {"artifact": "CONTEXT.md", "attested": true}
      ]
    },
    "2-PM": {
      "skill": "pm-review", "tiers": ["T3", "T4"],
      "outcomes": {"APPROVE": {"next": "2b"}, "REVISE": {"return_to": "2"}},
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "product_brief.md", "attested": true}
      ]
    },
    "2b": {
      "skill": "grace-init, grace-plan", "tiers": ["T3", "T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE"}
      ]
    },
    "3": {
      "skill": "design-rubric, design-first", "tiers": ["T2", "T3", "T4"],
      "when": {"condition": "frontend", "equals": true},
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE", "tiers": ["T3", "T4"]}
      ]
    },
    "3r": {
      "skill": "risk-review", "tiers": ["T4"],
      "outcomes": {"PASS": {"next": "4"}, "REVISE": {"return_to": "2"}, "STOP": {"stop": true}},
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE"},
        {"artifact": "docs/knowledge-graph.xml", "attested": true}
      ]
    },
    "4": {
      "skill": "contract", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "evidence-handoff.json", "attested": true, "json_pointer": "/decision", "equals": "delivery"},
        {"artifact": "pm-review.json", "attested": true, "json_pointer": "/status", "equals": "APPROVE", "tiers": ["T3", "T4"]},
        {"artifact": "docs/requirements.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/technology.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/development-plan.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/verification-plan.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/knowledge-graph.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "docs/operational-packets.xml", "attested": true, "tiers": ["T3", "T4"]},
        {"artifact": "design-contract.json", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": ".design-contract-attestation", "sha256_of": "design-contract.json", "when": {"condition": "frontend", "equals": true}},
        {"artifact": "api-contract.json", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": "docs/wireframe-*.md", "attested": true, "when": {"condition": "frontend", "equals": true}},
        {"artifact": "risk-review.json", "attested": true, "json_pointer": "/verdict", "equals": "PASS", "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/status", "in": ["ready", "complete"], "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/rollback/defined", "equals": true, "tiers": ["T4"]}
      ]
    },
    "4b": {
      "skill": "judge contract", "tiers": ["T2", "T3", "T4"],
      "outcomes": {"PASS": {"next": "4c"}, "CONDITIONAL": {"return_to": "4"}, "FAIL": {"return_to": "4"}},
      "requires": [{"artifact": "contract.json", "attested": true}]
    },
    "4c": {
      "skill": "visualization", "tiers": ["T2", "T3", "T4"],
      "phase_process": "visualization",
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS"},
        {"artifact": "docs/stories/index.json", "attested": true}
      ]
    },
    "5": {
      "skill": "to-issues", "tiers": ["T2", "T3", "T4"],
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS"},
        {"artifact": "SUPERVISION.md", "attested": true}
      ],
      "human_gate": "viz_before_tickets"
    },
    "5.5": {
      "skill": "scaffold", "tiers": ["T3", "T4"],
      "phase_process": "scaffold",
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "task_plan.md", "attested": true},
        {"artifact": "issues-manifest.json", "attested": true, "json_pointer": "/status", "equals": "approved"},
        {"artifact": "docs/knowledge-graph.xml", "attested": true}
      ]
    },
    "6f": {
      "skill": "targeted change or diagnose+tdd", "tiers": ["T0", "T1"],
      "requires": []
    },
    "6": {
      "skill": "build-loop, tdd", "tiers": ["T2", "T3", "T4"],
      "phase_process": "build-loop",
      "outcomes": {"PASS": {"next": "7"}, "CONTRACT_GAP": {"return_to": "4"}, "SCAFFOLD_DRIFT": {"return_to": "5.5"}, "RESTART": {"return_to": "5"}, "SPLIT_REQUIRED": {"return_to": "5"}},
      "requires": [
        {"artifact": "contract.json", "attested": true},
        {"artifact": "issues-manifest.json", "attested": true, "json_pointer": "/status", "equals": "approved"},
        {"artifact": "scaffold-manifest.json", "attested": true, "json_pointer": "/status", "equals": "ready", "tiers": ["T3", "T4"]},
        {"artifact": "iteration-contract.json", "attested": true, "json_pointer": "/status", "equals": "ready"}
      ],
      "human_gate": "contract_locked"
    },
    "7": {
      "skill": "judge feature, code-review-expert", "tiers": ["T0", "T1", "T2", "T3", "T4"],
      "outcomes": {"PASS": {"stop": true}, "CONDITIONAL": {"return_to": "6"}, "FAIL": {"return_to": "6"}},
      "requires": [
        {"artifact": "iteration-budget.json", "attested": true, "json_pointer": "/verdict", "equals": "PASS", "tiers": ["T2", "T3", "T4"]},
        {"artifact": "scaffold-integrity.json", "attested": true, "json_pointer": "/verdict", "in": ["PASS", "SCAFFOLD_DRIFT"], "tiers": ["T2", "T3", "T4"]},
        {"artifact": "iteration-review.json", "attested": true, "json_pointer": "/acceptor/verdict", "equals": "PASS", "tiers": ["T2", "T3", "T4"]},
        {"artifact": "iteration-dashboard.json", "attested": true, "json_pointer": "/status", "equals": "PASS", "tiers": ["T2", "T3", "T4"]},
        {"artifact": "build-evidence.json", "attested": true, "json_pointer": "/status", "equals": "complete"},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/status", "in": ["ready", "complete"], "tiers": ["T4"]},
        {"artifact": "rollout-plan.json", "attested": true, "json_pointer": "/rollback/defined", "equals": true, "tiers": ["T4"]}
      ],
      "completion": {
        "requires": [
          {"artifact": "code-review.md", "attested": true},
          {"artifact": "feature-judge-report.json", "attested": true, "json_pointer": "/data/verdict", "equals": "PASS", "tiers": ["T2", "T3", "T4"]}
        ],
        "human_gate": "human_acceptance"
      }
    }
  },
  "artifact_owners": {
    "product_brief.md": {"producer_phase": "-1", "template": "templates/project/product_brief.md"},
    "evidence-handoff.json": {"producer_phase": "-1", "template": "templates/project/evidence-handoff.json", "schema": "templates/project/evidence-handoff.schema.json", "media_type": "application/json"},
    "business_model.md": {"producer_phase": "-1"},
    "docs/research-state.json": {"producer_phase": "0", "template": "templates/project/docs/research-state.json", "schema": "templates/project/research-state.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    "CONTEXT.md": {"producer_phase": "1"},
    "task_plan.md": {"producer_phase": "2"},
    "docs/stories/index.json": {"producer_phases": ["1", "2"], "template": "templates/project/docs/stories/index.json", "schema": "templates/project/docs/stories/index.schema.json", "media_type": "application/json"},
    "pm-review.json": {"producer_phase": "2-PM", "template": "templates/project/pm-review.json", "schema": "templates/project/pm-review.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    "docs/requirements.xml": {"producer_phase": "2b"},
    "docs/technology.xml": {"producer_phase": "2b"},
    "docs/development-plan.xml": {"producer_phase": "2b", "template": "templates/project/docs/development-plan.xml"},
    "docs/verification-plan.xml": {"producer_phase": "2b", "template": "templates/project/docs/verification-plan.xml"},
    "docs/knowledge-graph.xml": {"producer_phase": "2b", "template": "templates/project/docs/knowledge-graph.xml"},
    "docs/operational-packets.xml": {"producer_phase": "2b"},
    "design-contract.json": {"producer_phase": "3", "template": "templates/project/design-contract.json", "schema": "templates/project/design-contract.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    ".design-contract-attestation": {"producer_phase": "3"},
    "api-contract.json": {"producer_phase": "3", "template": "templates/project/api-contract.json", "schema": "templates/project/api-contract.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    "docs/wireframe-*.md": {"producer_phase": "3"},
    "risk-review.json": {"producer_phase": "3r", "template": "templates/project/risk-review.json", "schema": "templates/project/risk-review.schema.json", "media_type": "application/json"},
    "rollout-plan.json": {"producer_phase": "3r", "template": "templates/project/rollout-plan.json", "schema": "templates/project/rollout-plan.schema.json", "media_type": "application/json"},
    "contract.json": {"producer_phase": "4", "template": "templates/project/contract.json", "schema": "templates/project/contract.schema.json", "media_type": "application/json"},
    "judge-report.json": {"producer_phase": "4b", "template": "templates/project/judge-report.json", "schema": "templates/project/judge-report.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    "SUPERVISION.md": {"producer_phase": "4c"},
    "issues-manifest.json": {"producer_phase": "5", "template": "templates/project/issues-manifest.json", "schema": "templates/project/issues-manifest.schema.json", "media_type": "application/json"},
    "scaffold-manifest.json": {"producer_phase": "5.5", "template": "templates/project/scaffold-manifest.json", "schema": "templates/project/scaffold-manifest.schema.json", "media_type": "application/json"},
    "iteration-contract.json": {"producer_phase": "5.5", "template": "templates/project/iteration-contract.json", "schema": "templates/project/iteration-contract.schema.json", "media_type": "application/json"},
    "iteration-budget.json": {"producer_phase": "6", "template": "templates/project/iteration-budget.json", "schema": "templates/project/iteration-budget.schema.json", "media_type": "application/json"},
    "scaffold-integrity.json": {"producer_phase": "6", "template": "templates/project/scaffold-integrity.json", "schema": "templates/project/scaffold-integrity.schema.json", "media_type": "application/json"},
    "iteration-review.json": {"producer_phase": "6", "template": "templates/project/iteration-review.json", "schema": "templates/project/iteration-review.schema.json", "media_type": "application/json"},
    "iteration-dashboard.json": {"producer_phase": "6", "template": "templates/project/iteration-dashboard.json", "schema": "templates/project/iteration-dashboard.schema.json", "media_type": "application/json"},
    "build-evidence.json": {"producer_phases": ["6f", "6"], "template": "templates/project/build-evidence.json", "schema": "templates/project/build-evidence.schema.json", "media_type": "application/json"},
    "feature-judge-report.json": {"producer_phase": "7", "template": "templates/project/feature-judge-report.json", "schema": "templates/project/feature-judge-report.schema.json", "media_type": "application/json", "template_mode": "draft-valid"},
    "code-review.md": {"producer_phase": "7"}
  },
  "artifact_contracts": {
    ".pipeline-state.json": {"producer": "setup-pipeline", "schema": "templates/project/pipeline-state.schema.json", "media_type": "application/json"},
    "model-bindings.json": {"producer": "project_owner", "schema": "templates/project/model-bindings.schema.json", "media_type": "application/json"},
    "role-assignment.json": {"producer": "project_owner", "schema": "templates/project/role-assignment.schema.json", "media_type": "application/json"},
    "model-conformance/*.json": {"producer": "model-conformance", "schema": "templates/project/model-conformance.schema.json", "media_type": "application/json"},
    "cross-model-review/*.json": {"producer": "cross-model-review", "schema": "templates/project/cross-model-review.schema.json", "media_type": "application/json"},
    "docs/views/*.json": {"producer": "visualization", "schema": "templates/project/viewpoint.schema.json", "media_type": "application/json"},
    ".build-loop/iterations/*/handoff.json": {"producer": "phase-6-role", "schema": "templates/project/role-handoff.schema.json", "media_type": "application/json"},
    "handoff.json": {"producer": "phase-6-role", "schema": "templates/project/role-handoff.schema.json", "media_type": "application/json"},
    ".kaeru/*.json": {"producer": "kaeru-adapter", "schema": "templates/project/kaeru-memory-ref.schema.json", "media_type": "application/json"}
  },
  "gate_owners": {
    "contract_locked": "4b",
    "viz_before_tickets": "4c",
    "human_acceptance": "7"
  },
  "human_requests": {
    "model_bindings": {
      "authority": "project_owner",
      "question": "Which concrete runtime/model IDs should be used for every capability profile required by the selected route?",
      "why_needed": "The pipeline cannot verify capability coverage or independent review roles until project-owned bindings are explicit.",
      "evidence_refs": ["model-bindings.json", "product_brief.md"],
      "setup_refs": ["docs/agent/COMPAT.md", "docs/human/SETUP.md"],
      "response": {
        "mode": "file",
        "path": "model-bindings.json",
        "schema": "model-bindings.schema.json"
      },
      "allowed_responses": ["configure_required_profiles", "defer_with_reason"],
      "consequences": {
        "on_submit": "The agent validates the exact IDs and role separation, then resumes the selected route.",
        "on_defer": "The ledger remains unchanged and no model-bound phase starts."
      },
      "resume_action": "Validate model-bindings.json, then rerun setup-pipeline status."
    },
    "contract_locked": {
      "authority": "product_owner and technical_owner for T3/T4; product_owner otherwise",
      "question": "Does the judged contract correctly lock scope, user flow, integrations, risks, and acceptance criteria for implementation?",
      "why_needed": "Implementation must not start until product authority accepts delivery intent and, for T3/T4, technical authority accepts the implementation boundary.",
      "evidence_refs": ["contract.json", "judge-report.json", "product_brief.md"],
      "setup_refs": ["docs/human/PIPELINE.md"],
      "response": {
        "mode": "inline",
        "format": {"action": "approve|revise", "comment": "required when revise"},
        "record_command": "setup-pipeline sign contract_locked --role product_owner --by <person-or-account>; for T3/T4 also sign --role technical_owner"
      },
      "allowed_responses": ["approve", "revise"],
      "consequences": {
        "on_approve": "Phase 6 may begin after the remaining machine preconditions pass.",
        "on_revise": "Return to the owning upstream phase, update evidence, and invalidate downstream approvals."
      },
      "resume_action": "Record contract_locked only after approve, then rerun setup-pipeline status."
    },
    "viz_before_tickets": {
      "authority": "technical_owner",
      "question": "Does the supervision view accurately show the approved plan, dependencies, human gates, and implementation slices before tickets are created?",
      "why_needed": "Ticket slicing commits the team to a technical delivery decomposition that the assigned technical owner must be able to supervise.",
      "evidence_refs": ["SUPERVISION.md", "contract.json", "judge-report.json", "task_plan.md"],
      "setup_refs": ["docs/human/PIPELINE.md"],
      "response": {
        "mode": "inline",
        "format": {"action": "approve|revise", "comment": "required when revise"},
        "record_command": "setup-pipeline sign viz_before_tickets --role technical_owner --by <person-or-account>"
      },
      "allowed_responses": ["approve", "revise"],
      "consequences": {
        "on_approve": "Issue creation may begin after the remaining machine preconditions pass.",
        "on_revise": "Revise the plan, contract, or supervision view and invalidate dependent approvals."
      },
      "resume_action": "Record viz_before_tickets only after approve, then rerun setup-pipeline status."
    },
    "human_acceptance": {
      "authority": "accountable_acceptor",
      "question": "Do the delivered behavior and independent review evidence satisfy the accepted contract in the real acceptance context?",
      "why_needed": "Automated and model reviews cannot substitute for accountable delivery acceptance.",
      "evidence_refs": ["build-evidence.json", "feature-judge-report.json", "code-review.md", "contract.json"],
      "setup_refs": ["docs/human/PIPELINE.md"],
      "response": {
        "mode": "inline",
        "format": {"action": "accept|reject", "comment": "required when reject"},
        "record_command": "setup-pipeline sign human_acceptance --role accountable_acceptor --by <person-or-account>"
      },
      "allowed_responses": ["accept", "reject"],
      "consequences": {
        "on_accept": "The selected route may become complete after completion preflight passes.",
        "on_reject": "Delivery stays incomplete; record the failed acceptance evidence and reopen the owning phase."
      },
      "resume_action": "Record human_acceptance only after accept, then run the Phase 7 completion check."
    }
  },
  "invalidations": {
    "product_brief.md": ["docs/research-state.json", "CONTEXT.md", "task_plan.md", "pm-review.json", "docs/requirements.xml", "docs/technology.xml", "docs/development-plan.xml", "docs/verification-plan.xml", "docs/knowledge-graph.xml", "docs/operational-packets.xml", "risk-review.json", "rollout-plan.json", "contract.json", "judge-report.json", "SUPERVISION.md", "issues-manifest.json", "scaffold-manifest.json", "iteration-contract.json", "iteration-budget.json", "scaffold-integrity.json", "iteration-review.json", "build-evidence.json", "iteration-dashboard.json"],
    "evidence-handoff.json": ["docs/research-state.json", "CONTEXT.md", "task_plan.md", "pm-review.json", "docs/requirements.xml", "docs/technology.xml", "docs/development-plan.xml", "docs/verification-plan.xml", "docs/knowledge-graph.xml", "docs/operational-packets.xml", "risk-review.json", "rollout-plan.json", "contract.json", "judge-report.json", "SUPERVISION.md", "issues-manifest.json", "scaffold-manifest.json", "iteration-contract.json", "iteration-budget.json", "scaffold-integrity.json", "iteration-review.json", "build-evidence.json", "iteration-dashboard.json"],
    "business_model.md": ["CONTEXT.md", "task_plan.md", "pm-review.json", "docs/requirements.xml", "docs/technology.xml", "docs/development-plan.xml", "docs/verification-plan.xml", "docs/knowledge-graph.xml", "docs/operational-packets.xml", "risk-review.json", "rollout-plan.json", "contract.json", "judge-report.json", "SUPERVISION.md", "issues-manifest.json", "scaffold-manifest.json", "iteration-contract.json", "iteration-budget.json", "scaffold-integrity.json", "iteration-review.json", "build-evidence.json", "iteration-dashboard.json"],
